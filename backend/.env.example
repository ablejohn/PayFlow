# PayFlow API — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — this file (.env.example) is safe to commit

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/payflow
DB_MAX_CONNECTIONS=10

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── AWS S3 (for invoice PDF storage) ────────────────────────────────────────
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=payflow-invoices-dev
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
