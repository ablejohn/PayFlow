{
  "name": "payflow-api",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS payment & invoice management API",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "nodemon server.js",
    "test":      "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit",
    "test:int":  "jest tests/integration",
    "db:migrate": "node db/migrate.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3":         "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "bcryptjs":                   "^2.4.3",
    "cors":                       "^2.8.5",
    "dotenv":                     "^16.4.5",
    "express":                    "^4.19.2",
    "express-rate-limit":         "^7.3.1",
    "helmet":                     "^7.1.0",
    "jsonwebtoken":                "^9.0.2",
    "nodemon":                    "^3.1.4",
    "pdfkit":                     "^0.15.0",
    "pg":                         "^8.12.0",
    "winston":                    "^3.13.0",
    "zod":                        "^3.23.8"
  },
  "devDependencies": {
    "jest":       "^29.7.0",
    "supertest":  "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
